<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://monitorDetailView.title"
      focusComponent="form">
    <data>
        <instance id="monitorDc"
                  class="com.company.onboarding.entity.Monitor">
            <fetchPlan extends="_base">
            </fetchPlan>
            <loader id="monitorDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveCloseAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="monitorDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <datePicker id="dateTestField" property="dateTest"/>
            <timePicker id="timeTestField" property="timeTest" min="06:00" max="22:00" step="30m" />
            <integerField id="lowpresField" property="lowpres" max="180" min="20" requiredMessage="Укажите значение"/>
            <integerField id="upperpresField" property="upperpres" min="60" max="260" requiredMessage="Укажите значение"/>
            <integerField id="pulseField" property="pulse" min="20" max="200" requiredMessage="Укажите значение"/>
            <select id="statusField" property="status"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveCloseAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
